REACT_APP_GOOGLE_CLIENT_ID=
REACT_APP_PULSE_SERVER_URL=http://localhost:8080
NODE_ENV=development

# Mock Server Configuration
# Set to 'true' to use mock data instead of real API calls
REACT_APP_USE_MOCK_SERVER=true

# Mock API response delay (in milliseconds)
REACT_APP_MOCK_DELAY=500

# Mock error rate (0-1, where 0 = no errors, 1 = all errors)
REACT_APP_MOCK_ERROR_RATE=0

# Enable mock API request logging
REACT_APP_MOCK_LOGGING=true