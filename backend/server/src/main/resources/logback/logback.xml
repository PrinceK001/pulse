<configuration scan="true" scanPeriod="1 seconds">
    <property scope="context" name="HOSTNAME" value="${HOSTNAME}"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %date %highlight(%+5level) %-26thread  %logger{36} %green(%msg) %n
            </pattern>
        </encoder>
    </appender>

    <logger name="org.dreamhorizon" level="trace"/>
    <logger name="io.netty" level="info"/>
    <logger name="org.jboss.resteasy" level="info"/>
    <logger name="org.apache" level="info"/>
     <!-- Prevent LoggerFilter from logging request bodies (prevents OOM on large file uploads) -->
    <logger name="com.dream11.rest.filter.LoggerFilter" level="info"/>
    
    <root level="debug">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>