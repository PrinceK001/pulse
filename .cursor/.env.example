# Cursor MCP Server Credentials
# Copy this file to .env and fill in your actual values
# Command: cp .cursor/.env.example .cursor/.env
#
# IMPORTANT: Never commit .cursor/.env to version control

# ============================================
# GITHUB MCP
# ============================================
# Generate at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# ============================================
# ATLASSIAN (JIRA + CONFLUENCE) MCP
# ============================================
# Generate API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://dream11.atlassian.net
JIRA_USERNAME=your.name@dream11.com
JIRA_API_TOKEN=your_atlassian_api_token_here

CONFLUENCE_URL=https://dream11.atlassian.net/wiki
CONFLUENCE_USERNAME=your.name@dream11.com
CONFLUENCE_API_TOKEN=your_atlassian_api_token_here
