# Pulse Observability - Environment Variables Template
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env

# ============================================
# FRONTEND CONFIGURATION (pulse-ui)
# ============================================
REACT_APP_GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID_DUMMY.apps.googleusercontent.com
REACT_APP_PULSE_SERVER_URL=http://localhost:8080
NODE_ENV=production
REACT_APP_USE_MOCK_SERVER=false
REACT_APP_MOCK_DELAY=500
REACT_APP_MOCK_ERROR_RATE=0
REACT_APP_MOCK_LOGGING=false
REACT_APP_GCP_MULTI_TENANT_ENABLED=true
REACT_APP_FIREBASE_API_KEY=DUMMY_FIREBASE_API_KEY
REACT_APP_FIREBASE_PROJECT_ID=dummy-project-id
REACT_APP_GCP_TENANTS=tenant1-xxxxx,tenant2-yyyyy
REACT_APP_GCP_TENANT_LABELS=tenant1-xxxxx:Tenant1,tenant2-yyyyy:Tenant2
REACT_APP_FIREBASE_AUTH_DOMAIN=dummy-project-id.firebaseapp.com

# ============================================
# LOGIN CONFIGURATION
GOOGLE_OAUTH_ENABLED=false
# ============================================

# S3 Configuration
S3_BUCKET_NAME=pulse-otel-config
CONFIG_DETAILS_S3_FILE_PATH=config/pulse-config.json
INTERACTION_DETAILS_S3_FILE_PATH=config/interaction-config.json

# CloudFront Configuration (set to SKIP to skip invalidation during testing)
CLOUDFRONT_DISTRIBUTION_ID=SKIP
CONFIG_CLOUDFRONT_ASSET_PATH=/config/pulse-config.json
INTERACTION_CLOUDFRONT_ASSET_PATH=/config/interaction-config.json
# ============================================
# BACKEND CONFIGURATION (pulse-server)
# ============================================

INTERACTION_CONFIG_URL=interactionConfigUrl
LOGS_COLLECTOR_URL=logsCollectorUrl
METRIC_COLLECTOR_URL=metricCollectorUrl
SPAN_COLLECTOR_URL=spanCollectorUrl
CUSTOM_EVENT_COLLECTOR_URL=customEventCollectorUrl

# Application Configuration
CONFIG_SERVICE_APPLICATION_BQACCESSTOKENTTLSECONDS=600
CONFIG_SERVICE_APPLICATION_CLOUDRUNTOKENTTLSECONDS=600
CONFIG_SERVICE_APPLICATION_CONCORDBASEURL=https://concord.example.com
CONFIG_SERVICE_APPLICATION_CRONMANAGERBASEURL=http://pulse-alerts-cron:4000/cron
CONFIG_SERVICE_APPLICATION_DATAHIGHWAYBASEURL=https://data-highway-admin.example.com
CONFIG_SERVICE_APPLICATION_GCPDATAFLOWPROJECTURL=https://dataflow.googleapis.com/v1b3/projects/example-project
CONFIG_SERVICE_APPLICATION_GRAFANABASEURL=https://grafana.example.com
CONFIG_SERVICE_APPLICATION_GUARDIANBASEURL=https://guardian.example.com
CONFIG_SERVICE_APPLICATION_HODORBASEURL=https://hodor.example.com
CONFIG_SERVICE_APPLICATION_INTERACTIONDETAILCLOUDFRONTASSETPATH=/uat/InteractionDetails.json
CONFIG_SERVICE_APPLICATION_INTERACTIONDETAILSS3BUCKETFILEPATH=uat/InteractionDetails.json
CONFIG_SERVICE_APPLICATION_MSDBASEURL=https://msd.example.com
CONFIG_SERVICE_APPLICATION_PULSEAIBASEURL=https://pulse-agent-service.example.com
CONFIG_SERVICE_APPLICATION_PULSES3BUCKETNAME=pulse-ux-bucket-uat-dummy
CONFIG_SERVICE_APPLICATION_RBACIDSUFFIX=-uat
CONFIG_SERVICE_APPLICATION_SERVICEURL=http://pulse-server:8080
CONFIG_SERVICE_APPLICATION_SQLPOPULATEANOMALYBATCHSIZE=400
CONFIG_SERVICE_APPLICATION_SQLPOPULATEMETRICBATCHSIZE=750
CONFIG_SERVICE_APPLICATION_STREAMVERSEBASEURL=https://streamverse.example.com
CONFIG_SERVICE_APPLICATION_TOKENREFRESHTHREADPOOLSIZE=2
CONFIG_SERVICE_APPLICATION_TTLMILLISCONCORDEVENTS=300000
CONFIG_SERVICE_APPLICATION_USERAUTHURL=https://user-info.example.com/user
CONFIG_SERVICE_APPLICATION_USEREXPERIMENTATIONURL=https://experiment.example.com
CONFIG_SERVICE_APPLICATION_GOOGLEOAUTHCLIENTID=GOOGLE_OAUTH_CLIENT_ID_DUMMY.apps.googleusercontent.com
CONFIG_SERVICE_APPLICATION_JWTSECRET=change_me_dev_jwt_secret_at_least_32_chars
CONFIG_SERVICE_APPLICATION_GCP_PROJECT_ID=dummy
CONFIG_SERVICE_APPLICATION_WEBHOOKURL=dummyWebHookUrl

# Vault Service Configuration (Secrets)
VAULT_SERVICE_DREAMAUTHAPIKEY=DUMMY_DREAMAUTH_API_KEY
VAULT_SERVICE_GRAPHANADASHBOARDTOKEN=DUMMY_GRAFANA_DASHBOARD_TOKEN
VAULT_SERVICE_INTERACTIONDETAILCLOUDFRONTDISTRIBUTIONID=DUMMY_CLOUDFRONT_DISTRIBUTION_ID
VAULT_SERVICE_SINKSTORECONFIGHOST=https://es.example.com:443
VAULT_SERVICE_SINKSTORECONFIGPASSWORD=DUMMY_SINKSTORE_PASSWORD
VAULT_SERVICE_SINKSTORECONFIGUSERNAME=DUMMY_SINKSTORE_USERNAME
VAULT_SERVICE_SINKTABLE=sample_table_uat
VAULT_SERVICE_SLACKAUTOBOTTOKEN=xoxb-DUMMY-SLACK-AUTO-BOT-TOKEN
VAULT_SERVICE_SLACKBOTAPPTOKEN=xapp-DUMMY-SLACK-BOT-APP-TOKEN
VAULT_SERVICE_SLACKBOTTOKEN=xoxb-DUMMY-SLACK-BOT-TOKEN
VAULT_SERVICE_SLACKENDPOINT=https://hooks.slack.com/services/DUMMY/PLACE/HOLDER
VAULT_SERVICE_STREAMVERSEAPITOKEN=DUMMY_STREAMVERSE_API_JWT_TOKEN
VAULT_ENCRYPTION_MASTER_KEY=DUMMY_ENCRYPTION_MASTER_KEY
# ============================================
# OTEL COLLECTOR CONFIGURATION
# ============================================
OTEL_CLICKHOUSE_DATABASE=otel
OTEL_CLICKHOUSE_USER=pulse_user
OTEL_CLICKHOUSE_PASSWORD=pulse_password
# ============================================
# QUERY ENGINE CONFIGURATION
# ============================================
# Query engine selection: 'athena' (default) or 'gcp'
# Currenly only athena is supported
CONFIG_SERVICE_APPLICATION_QUERY_ENGINE=athena

# ATHENA CONFIGURATION
# ============================================
CONFIG_SERVICE_APPLICATION_ATHENA_REGION=ap-south-1
CONFIG_SERVICE_APPLICATION_ATHENA_DATABASE=pulse_athena_db
CONFIG_SERVICE_APPLICATION_ATHENA_OUTPUT_LOCATION=s3://puls-otel-config/

# AWS CREDENTIALS (for Athena)
# ============================================
AWS_ACCESS_KEY_ID=abc
AWS_SECRET_ACCESS_KEY=abc
AWS_SESSION_TOKEN=abc

# ============================================
# OPENFGA CONFIGURATION
# ============================================
OPENFGA_API_URL=http://openfga:8080
OPENFGA_STORE_ID=OPENFGA_STORE_ID_PLACEHOLDER
OPENFGA_MODEL_ID=OPENFGA_MODEL_ID_PLACEHOLDER
OPENFGA_ENABLED=true

# ============================================
# SLACK CONFIGURATION
# ============================================
SLACK_CLIENT_ID=DUMMY_SLACK_CLIENT_ID
SLACK_CLIENT_SECRET=DUMMY_SLACK_CLIENT_SECRET
SLACK_OAUTH_SCOPES=chat:write,channels:read
SLACK_REDIRECT_URI=http://localhost:3000/integrations/slack/callback

